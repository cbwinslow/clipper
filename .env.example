# VAClip Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# ============================================================
# OPTIONAL - OpenRouter (only needed for reranking phase)
# ============================================================
# Get a free API key at https://openrouter.ai
# Leave blank to disable OpenRouter entirely (recommended for MVP)
OPENROUTER_API_KEY=

# OpenRouter model to use for reranking (optional)
# Free tier models: mistralai/mistral-7b-instruct, etc.
OPENROUTER_MODEL=

# ============================================================
# OPTIONAL - Config override path
# ============================================================
# Override default configs/app.yaml with a custom config
VACLIP_CONFIG_PATH=

# ============================================================
# OPTIONAL - Path overrides
# ============================================================
VACLIP_INPUT_DIR=./input
VACLIP_OUTPUT_DIR=./output
VACLIP_CACHE_DIR=./cache
VACLIP_MODELS_DIR=./models
VACLIP_LOGS_DIR=./logs

# ============================================================
# OPTIONAL - Transcription overrides
# ============================================================
# Override model size: tiny, base, small, medium, large-v2, large-v3
VACLIP_TRANSCRIPTION__MODEL_SIZE=large-v3

# Override compute type: float16, int8_float16, int8
# Use int8_float16 if you get CUDA out-of-memory errors
VACLIP_TRANSCRIPTION__COMPUTE_TYPE=float16

# Override device: cuda, cpu, auto
VACLIP_TRANSCRIPTION__DEVICE=cuda

# ============================================================
# OPTIONAL - HuggingFace (for pyannote diarization, future)
# ============================================================
# Required only if you install pyannote.audio for speaker diarization
HUGGINGFACE_TOKEN=
